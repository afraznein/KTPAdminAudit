# Local dev files (not committed)
nul

# Compiled plugins (keep source, compile fresh)
# Note: We include .amxx for convenience, but source is authoritative
compiled/

# Editor backups
*.bak
*~
*.swp

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# machine-local Claude permissions (skills ARE published)
.claude/settings.local.json

# Compiled plugins belong in the gitignored compiled/ dir, never the repo root.
# A tracked root .amxx went stale by 7 months while install docs pointed at it.
/*.amxx
